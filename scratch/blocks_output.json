      "problem": "Write a program that reads two integers from the user (numerator and denominator). If the denominator is 0, throw an ArithmeticException with the message \"Cannot divide by zero!\". Catch the exception and print the error message. If valid, calculate and print the result as a double with 2 decimal places.",
      "testCases": [
        {
          "input": "10\n0",
          "expectedOutput": "Cannot divide by zero!"
        },
        {
          "input": "10\n4",
          "expectedOutput": "Result: 2.50"
        },
        {
          "input": "7\n2",
          "expectedOutput": "Result: 3.50"
        }
      ],
      "constraints": "Use try-catch. Throw exception when denominator is 0.",
      "inputFormat": "Two integers on separate lines: numerator, then denominator.",
      "starterCode": {
        "lines": [
          "import java.util.Scanner;",
          "",
          "public class Main {",
          "    public static void main(String[] args) {",
          "        // Write your code here",
          "    }",
          "}"
        ],
        "language": "java"
      },
      "outputFormat": "Result: <value>\nOr: Cannot divide by zero!",
      "hiddenTestCases": [
        {
          "input": "100\n0",
          "expectedOutput": "Cannot divide by zero!"
        },
        {
          "input": "15\n3",
          "expectedOutput": "Result: 5.00"
        }
      ]
    }
